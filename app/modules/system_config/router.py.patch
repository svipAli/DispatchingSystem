import sys
lines = open('/Users/zhangli/Works/PyCharmProjects/DispatchingSystem/app/modules/system_config/router.py').readlines()
out = []
for line in lines:
    out.append(line)
    if 'db: AsyncSession = Depends(get_db),' in line and '_: bool' not in line:
        out.append('    _: bool = Depends(require_admin),\n')
    elif 'db: AsyncSession = Depends(get_db)' in line and '_: bool' not in line and '):' in line:
        # Replace the closing paren with comma + admin param
        out[-1] = line.replace('db: AsyncSession = Depends(get_db)):', 'db: AsyncSession = Depends(get_db),\n    _: bool = Depends(require_admin),\n):')
open('/Users/zhangli/Works/PyCharmProjects/DispatchingSystem/app/modules/system_config/router.py', 'w').writelines(out)
